        <mxCell id="input" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FBF8F1;strokeColor=#D9D0C3;fontColor=#15202B;fontFamily=Arial;fontSize=22;align=left;verticalAlign=top;spacing=26;" value="&lt;b&gt;Entradas del proyecto&lt;/b&gt;&lt;br&gt;&lt;br&gt;• Proyecto, cliente y monto&lt;br&gt;• Margen objetivo / esperado&lt;br&gt;• Horas estimadas o saturación&lt;br&gt;&lt;br&gt;&lt;font color=&quot;#61707C&quot;&gt;Hoja: INPUT_PROYECTO&lt;/font&gt;" vertex="1">
          <mxGeometry height="220" width="390" x="10" y="560" as="geometry" />
        </mxCell>
        <mxCell id="prob" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FBF8F1;strokeColor=#D9D0C3;fontColor=#15202B;fontFamily=Arial;fontSize=22;align=left;verticalAlign=top;spacing=26;" value="&lt;b&gt;Probabilidad de adjudicación&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&quot;font-family: Consolas; font-size: 24px;&quot;&gt;P = R × C × E&lt;/span&gt;&lt;br&gt;&lt;br&gt;R = relación cliente&lt;br&gt;C = competencia&lt;br&gt;E = experiencia interna" vertex="1">
          <mxGeometry height="260" width="290" x="1450" y="167" as="geometry" />
        </mxCell>
        <mxCell id="ct" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FBF8F1;strokeColor=#D9D0C3;fontColor=#15202B;fontFamily=Arial;fontSize=22;align=left;verticalAlign=top;spacing=28;" value="&lt;b&gt;CT: Complejidad Técnica&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#61707C&quot;&gt;Checklist técnico con bloques ponderados&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;table border=&quot;0&quot; cellpadding=&quot;6&quot;&gt;&lt;tr&gt;&lt;td bgcolor=&quot;#176B87&quot;&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;H 25&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#2F8A5B&quot;&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;B 20&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#C9862D&quot;&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;D 15&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td bgcolor=&quot;#6F5F90&quot;&gt;&lt;font color=&quot;#FFFFFF&quot;&gt;&lt;b&gt;G 12&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font style=&quot;font-family: Consolas; font-size: 22px;&quot;&gt;CT = Σ(score_bloque × peso)&lt;/font&gt;&lt;br&gt;&lt;font color=&quot;#61707C&quot;&gt;Resultado: CT continuo 0-100 y CT discreto 1-5&lt;/font&gt;" vertex="1">
          <mxGeometry height="280" width="500" x="475" y="530" as="geometry" />
        </mxCell>
        <mxCell id="vec" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DDECE4;strokeColor=#BFD7C9;fontColor=#15202B;fontFamily=Arial;fontSize=21;align=left;verticalAlign=top;spacing=28;" value="&lt;b&gt;VEC: Valor Esperado de Cotizar&lt;/b&gt;&lt;br&gt;&lt;font color=&quot;#61707C&quot;&gt;Integra probabilidad, impacto, margen y capacidad&lt;/font&gt;&lt;br&gt;&lt;br&gt;&lt;font style=&quot;font-family: Consolas; font-size: 24px;&quot;&gt;&lt;b&gt;VEC = P × I × M × F_C&lt;/b&gt;&lt;/font&gt;&lt;br&gt;&lt;br&gt;I = MIN(monto / máximo, 1)&lt;br&gt;M = margen esperado / margen objetivo&lt;br&gt;F_C = EXP(-α × horas / horas disponibles)" vertex="1">
          <mxGeometry height="330" width="390" x="1020" y="132" as="geometry" />
        </mxCell>
